#:schema node_modules/wrangler/config-schema.json
name = "game-list"
main = ".open-next/worker.js"
compatibility_date = "2026-06-14"
compatibility_flags = ["nodejs_compat"]

# ----------------------------------------------------------------
# تنظیمات دقیق و نهایی برای حل ارور 404 فایل‌های استاتیک و CSSها
# ----------------------------------------------------------------
[assets]
directory = ".open-next/assets"
binding = "ASSETS"
base_dir = ".open-next/assets" # 👈 این خط را حتماً اضافه کن تا آدرس‌دهی دقیقاً ست شود

# ----------------------------------------------------------------
# اتصال به دیتابیس ابری KV
# ----------------------------------------------------------------
[[kv_namespaces]]
binding = "GAME_KV"
id = "a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1" 

[[kv_namespaces]]
binding = "NEXT_CACHE_WORKERS_KV"
preview_binding = "NEXT_CACHE_WORKERS_KV_PREVIEW"
id = "NEXT_CACHE_WORKERS_KV"

[vars]
NEXT_ANALYTICS_ID = ""
